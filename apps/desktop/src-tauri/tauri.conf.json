{
  "productName": "TULMEK",
  "version": "0.1.0",
  "identifier": "com.tulmek.app",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": "echo 'Build web with output:export first'"
  },
  "app": {
    "windows": [
      {
        "title": "TULMEK — Knowledge Hub",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/coast-guide-sahil/tulmek/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
